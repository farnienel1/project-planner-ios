rules_version = '2';
service cloud.firestore {
  // UUID / org strings may differ by case between clients and Firestore; rules must still match.
  function orgIdsMatch(a, b) {
    return a is string && b is string && a.lower() == b.lower();
  }
  
  // True if users/{auth.uid}.organizationId matches this org (string, case-insensitive, or DocumentReference path).
  function userOrgIdMatchesPath(organizationId) {
    return request.auth != null &&
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           'organizationId' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
           (
             (
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId is string &&
               orgIdsMatch(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId, organizationId)
             ) ||
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId == /databases/$(database)/documents/organizations/$(organizationId)
           );
  }
  
  // Member check by reading the parent org document. Do NOT use this when evaluating read on that same org doc
  // (circular get can deny access). For organizations/{organizationId} document reads, use resource.data.members instead.
  function isOrgMemberViaParentGet(organizationId) {
    return request.auth != null &&
           exists(/databases/$(database)/documents/organizations/$(organizationId)) &&
           'members' in get(/databases/$(database)/documents/organizations/$(organizationId)).data &&
           request.auth.uid in get(/databases/$(database)/documents/organizations/$(organizationId)).data.members;
  }
  
  // For subcollections under organizations/{organizationId}/… only (parent get is not the resource being read).
  function belongsToOrganization(organizationId) {
    return request.auth != null && (
      userOrgIdMatchesPath(organizationId) ||
      isOrgMemberViaParentGet(organizationId)
    );
  }
  
  // Helper function to check if user is admin of organization
  // Includes adminAccess so users with admin permissions can update org (e.g. members map on user delete).
  function isOrganizationAdmin(organizationId) {
    return request.auth != null && 
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           userOrgIdMatchesPath(organizationId) &&
           ((get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true) ||
            ('adminAccess' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminAccess == true) ||
            ('role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
  }
  
  // Helper function to check if current user is super admin or has admin access
  // Firestore rules only support boolean expressions, not if/let statements
  // 
  // WHO CAN CREATE USERS:
  // ✅ Super Admin (isSuperAdmin == true)
  // ✅ Admins (adminAccess == true OR role == 'admin')
  // ❌ Managers (manager == true) - CANNOT create users
  // ❌ Operatives (operativeMode == true) - CANNOT create users
  // 
  // This ensures only super admins and admins can create other users.
  // Managers and operatives can only create their own accounts (self-creation via website signup).
  function isAdminOrSuperAdmin() {
    return request.auth != null && 
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           (('isSuperAdmin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true) ||
            ('adminAccess' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminAccess == true) ||
            ('role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
  }
  
  // Helper function to validate organizationId exists
  function organizationExists(organizationId) {
    return exists(/databases/$(database)/documents/organizations/$(organizationId));
  }
  
  match /databases/{database}/documents {
    // Invitations - allow public read for verification (before user is authenticated)
    match /invitations/{invitationId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow update: if request.auth != null;
    }
    
    // Users collection - with better validation
    match /users/{userId} {
      allow read: if request.auth != null;
      allow list: if request.auth != null;
      
      // Allow create if:
      // 1. User is creating themselves (by email match - for signup flow), OR
      // 2. Current user is super admin or has admin access (for admin user creation)
      // 
      // IMPORTANT: We check self-creation FIRST because:
      // - During signup, users create their own account via the website
      // - This doesn't require admin permissions
      // - This is fast and reliable (no document reads)
      //
      // For admin creation, we use inline checks instead of the function
      // because functions can be unreliable during CREATE operations.
      // This directly checks the user document in the rule itself.
      allow create: if request.auth != null && (
        // Path 1: Self-creation (user creating their own account)
        // Email matches, and either no claim for this email in org or claim already points to this user (prevents duplicate accounts)
        (request.resource.data.email == request.auth.token.email &&
         (exists(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)/userEmails/$(request.resource.data.email)) == false ||
          get(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)/userEmails/$(request.resource.data.email)).data.userId == request.auth.uid)) ||
        // Path 2: Admin creation (admin/super admin creating other users e.g. invite)
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         (('isSuperAdmin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true) ||
          ('adminAccess' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminAccess == true) ||
          ('role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')))
      );
      
      // Allow update if:
      // 1. User updating themselves (always allow - they can update their own document including organizationId), OR
      // 2. Admin/Super Admin updating other users (for user management)
      allow update: if request.auth != null && (
        // User updating themselves - always allow (most permissive - can update anything including organizationId)
        request.auth.uid == userId ||
        // User updating themselves by email match
        (resource.data.email == request.auth.token.email && 
         request.resource.data.email == request.auth.token.email) ||
        // Admin/Super Admin updating other users
        isAdminOrSuperAdmin()
      ) && (
        // If user is updating themselves, allow any update (including organizationId)
        // If admin is updating others, validate organizationId changes
        request.auth.uid == userId ||
        !('organizationId' in request.resource.data) ||
        (('organizationId' in resource.data && orgIdsMatch(request.resource.data.organizationId, resource.data.organizationId)) ||
         // Allow setting organizationId if organization exists (for manual linking)
         (organizationExists(request.resource.data.organizationId) && isAdminOrSuperAdmin()))
      );
      
      // Allow delete if:
      // 1) User deleting themselves by uid, OR
      // 2) User deleting their own duplicate docs by email, OR
      // 3) Super Admin deleting any non-creator user in their organization, OR
      // 4) Admin (non-super) deleting non-admin/non-super users in their organization.
      allow delete: if request.auth != null && (
        request.auth.uid == userId ||
        (request.auth.token.email != null && resource.data.email == request.auth.token.email) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          orgIdsMatch(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId, resource.data.organizationId) &&
          (
            (
              ('isSuperAdmin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true) &&
              (
                !exists(/databases/$(database)/documents/organizations/$(resource.data.organizationId)) ||
                !('creatorUserId' in get(/databases/$(database)/documents/organizations/$(resource.data.organizationId)).data) ||
                get(/databases/$(database)/documents/organizations/$(resource.data.organizationId)).data.creatorUserId != userId
              )
            ) ||
            (
              isAdminOrSuperAdmin() &&
              !('isSuperAdmin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true) &&
              !('isSuperAdmin' in resource.data && resource.data.isSuperAdmin == true) &&
              !('adminAccess' in resource.data && resource.data.adminAccess == true) &&
              !('role' in resource.data && resource.data.role == 'admin')
            )
          )
        )
      );
    }

    // Organizations - with strict access control
    match /organizations/{organizationId} {
      // One user per email per org (must stay above the catch-all so writes are not widened by {collection}/**)
      match /userEmails/{emailKey} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && (
          isAdminOrSuperAdmin() ||
          request.resource.data.userId == request.auth.uid
        );
        allow delete: if request.auth != null && isAdminOrSuperAdmin();
      }
      
      // Org root document: must not call get(organizations/{organizationId}) inside the rule (same doc → circular deny).
      // Use resource.data.members for membership; userOrgIdMatchesPath for users/{uid}.organizationId.
      allow read: if request.auth != null && (
        userOrgIdMatchesPath(organizationId) ||
        ('members' in resource.data && request.auth.uid in resource.data.members)
      );
      
      allow list: if request.auth != null;
      
      allow create: if request.auth != null && 
                     request.resource.data.members[request.auth.uid] == 'admin';
      
      allow update: if isOrganizationAdmin(organizationId) ||
                     (request.auth != null &&
                      'members' in request.resource.data &&
                      request.auth.uid in request.resource.data.members &&
                      organizationExists(organizationId));
      
      allow delete: if false;
      
      match /projects/{projectId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow create, update: if request.auth != null &&
                                orgIdsMatch(request.resource.data.organizationId, organizationId) &&
                                belongsToOrganization(organizationId);
        allow delete: if isOrganizationAdmin(organizationId);
      }
      
      match /smallWorks/{smallWorkId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow create, update: if request.auth != null &&
                                orgIdsMatch(request.resource.data.organizationId, organizationId) &&
                                belongsToOrganization(organizationId);
        allow delete: if isOrganizationAdmin(organizationId);
      }
      
      match /clients/{clientId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow create, update: if request.auth != null &&
                                orgIdsMatch(request.resource.data.organizationId, organizationId) &&
                                belongsToOrganization(organizationId);
        allow delete: if isOrganizationAdmin(organizationId);
      }
      
      match /operatives/{operativeId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow create, update: if request.auth != null &&
                                orgIdsMatch(request.resource.data.organizationId, organizationId) &&
                                belongsToOrganization(organizationId);
        allow delete: if isOrganizationAdmin(organizationId);
      }
      
      match /bookings/{bookingId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow create, update: if request.auth != null &&
                                orgIdsMatch(request.resource.data.organizationId, organizationId) &&
                                belongsToOrganization(organizationId);
        allow delete: if isOrganizationAdmin(organizationId);
      }
      
      match /qualifications/{qualificationId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow write: if request.auth != null && belongsToOrganization(organizationId);
      }
      
      match /skills/{skillId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow write: if request.auth != null && belongsToOrganization(organizationId);
      }
      
      // Job types and other org settings (only jobTypes doc is used today). Org members need to sync job types when creating work.
      match /settings/{settingId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow write: if request.auth != null && belongsToOrganization(organizationId);
      }
      
      match /tasks/{taskId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow create, update: if request.auth != null &&
                                orgIdsMatch(request.resource.data.organizationId, organizationId) &&
                                belongsToOrganization(organizationId);
        allow delete: if isOrganizationAdmin(organizationId);
      }
      
      match /managers/{managerId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow create, update: if request.auth != null &&
                                orgIdsMatch(request.resource.data.organizationId, organizationId) &&
                                belongsToOrganization(organizationId);
        allow delete: if isOrganizationAdmin(organizationId);
      }
      
      match /notifications/{notificationId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow create, update: if request.auth != null &&
                                orgIdsMatch(request.resource.data.organizationId, organizationId) &&
                                belongsToOrganization(organizationId);
        allow delete: if isOrganizationAdmin(organizationId);
      }
      
      match /managerSiteBookings/{bookingId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow create, update: if request.auth != null &&
                                orgIdsMatch(request.resource.data.organizationId, organizationId) &&
                                belongsToOrganization(organizationId);
        allow delete: if request.auth != null && belongsToOrganization(organizationId);
      }
      
      match /holidayBookings/{bookingId} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow create, update: if request.auth != null &&
                                orgIdsMatch(request.resource.data.organizationId, organizationId) &&
                                belongsToOrganization(organizationId);
        allow delete: if isOrganizationAdmin(organizationId);
      }
      
      // Read-only fallback for unknown subcollections (avoid granting write to userEmails etc.)
      match /{collection}/{document=**} {
        allow read: if request.auth != null && belongsToOrganization(organizationId);
        allow write: if false;
      }
    }
  }
}
