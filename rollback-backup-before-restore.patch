index ab4c929..59cd919 100644
--- a/Project Planner/FirebaseBackend.swift	
+++ b/Project Planner/FirebaseBackend.swift	
@@ -478,6 +478,77 @@ class FirebaseBackend: ObservableObject {
             throw error
         }
     }
+
+    func changeCurrentUserEmail(currentPassword: String, newEmail: String) async throws -> String {
+        guard let user = currentUser, let currentEmail = user.email else {
+            throw NSError(domain: "AuthError", code: 401, userInfo: [NSLocalizedDescriptionKey: "No user signed in"])
+        }
+        let normalizedNewEmail = newEmail.trimmingCharacters(in: .whitespacesAndNewlines).lowercased()
+        let normalizedOldEmail = currentEmail.trimmingCharacters(in: .whitespacesAndNewlines).lowercased()
+        guard !normalizedNewEmail.isEmpty else {
+            throw NSError(domain: "AuthError", code: 400, userInfo: [NSLocalizedDescriptionKey: "New email cannot be empty."])
+        }
+        guard normalizedNewEmail != normalizedOldEmail else {
+            return normalizedOldEmail
+        }
+        guard let organizationId = currentOrganization?.firestoreDocumentId else {
+            throw NSError(domain: "AuthError", code: 400, userInfo: [NSLocalizedDescriptionKey: "Organization not loaded."])
+        }
+
+        let credential = EmailAuthProvider.credential(withEmail: currentEmail, password: currentPassword)
+        try await user.reauthenticate(with: credential)
+
+        let existing = try await db.collection("users")
+            .whereField("organizationId", isEqualTo: organizationId)
+            .whereField("email", isEqualTo: normalizedNewEmail)
+            .limit(to: 1)
+            .getDocuments(source: .server)
+        if let conflict = existing.documents.first, conflict.documentID != user.uid {
+            throw NSError(domain: "AuthError", code: 409, userInfo: [NSLocalizedDescriptionKey: "That email is already used by another user in this organization."])
+        }
+
+        try await user.updateEmail(to: normalizedNewEmail)
+
+        let batch = db.batch()
+        let userRef = db.collection("users").document(user.uid)
+        batch.setData([
+            "email": normalizedNewEmail,
+            "updatedAt": Timestamp(date: Date())
+        ], forDocument: userRef, merge: true)
+
+        let oldClaimRef = db.collection("organizations").document(organizationId).collection("userEmails").document(normalizedOldEmail)
+        let oldClaimSnap = try await oldClaimRef.getDocument(source: .server)
+        if let oldData = oldClaimSnap.data(), let claimedUserId = oldData["userId"] as? String, claimedUserId == user.uid {
+            batch.deleteDocument(oldClaimRef)
+        }
+        let newClaimRef = db.collection("organizations").document(organizationId).collection("userEmails").document(normalizedNewEmail)
+        batch.setData(["userId": user.uid], forDocument: newClaimRef, merge: true)
+
+        let operativesSnap = try await db.collection("organizations").document(organizationId)
+            .collection("operatives")
+            .whereField("email", isEqualTo: normalizedOldEmail)
+            .getDocuments(source: .server)
+        for doc in operativesSnap.documents {
+            batch.setData([
+                "email": normalizedNewEmail,
+                "updatedAt": Timestamp(date: Date())
+            ], forDocument: doc.reference, merge: true)
+        }
+
+        let managersSnap = try await db.collection("organizations").document(organizationId)
+            .collection("managers")
+            .whereField("email", isEqualTo: normalizedOldEmail)
+            .getDocuments(source: .server)
+        for doc in managersSnap.documents {
+            batch.setData([
+                "email": normalizedNewEmail,
+                "updatedAt": Timestamp(date: Date())
+            ], forDocument: doc.reference, merge: true)
+        }
+
+        try await batch.commit()
+        return normalizedNewEmail
+    }
     
     // MARK: - User Management
     
