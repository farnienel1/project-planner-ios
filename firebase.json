{
  "firestore": {
    "rules": "website/firestore.rules"
  },
  "functions": [
    {
      "source": "website/functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    },
    {
      "source": "website/functions-push",
      "codebase": "push",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ]
}
